# Database Configuration
DATABASE_URL=sqlite:///./carkey.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/smartcar

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-use-32-random-chars

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# Logging
LOG_LEVEL=INFO
